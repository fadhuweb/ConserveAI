# Google Earth Engine
GEE_PROJECT=your-gee-project-id
GEE_SERVICE_ACCOUNT=your-service-account@project.iam.gserviceaccount.com
GEE_KEY_FILE=secrets/gee-key.json
# For headless/Fly deployment, instead of a file path set the raw JSON key here
# (the full contents of the service-account .json) as a single secret:
# GEE_KEY_DATA={"type":"service_account",...}

# NASA Earthdata (FIRMS + POWER)
NASA_EARTHDATA_USERNAME=your-username
NASA_EARTHDATA_PASSWORD=your-password
NASA_FIRMS_API_KEY=your-firms-map-key

# Database (Neon in production — use the pooled or direct connection string)
DATABASE_URL=postgresql://user:password@localhost:5432/conserveai

# Auth
JWT_SECRET_KEY=change-this-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=8

# App
ENVIRONMENT=development          # "production" flips cookies to Secure/SameSite=None
LOG_LEVEL=INFO

# Frontend URL — used to build password-reset links AND allowed by CORS.
# In production set this to your Vercel domain, e.g. https://conserveai.vercel.app
FRONTEND_URL=http://localhost:5173

# Scheduler — shared secret the GitHub Actions cron sends (X-Job-Token header) to
# trigger POST /jobs/run-daily-forecast in production. Generate a long random value.
JOB_TRIGGER_TOKEN=

# Email (Gmail SMTP) — used to email managers their password-reset / first-login links
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=                       # your Gmail address
SMTP_PASSWORD=                   # a Gmail App Password (not your normal password)
SMTP_FROM=                       # defaults to SMTP_USER if blank
